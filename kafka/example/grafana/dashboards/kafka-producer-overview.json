        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "description": "X-axis: time. Y-axis: transactional operation rate split by operation and status. Unit: operations per second.",
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (operation, status) (rate(kafka_producer_operations_total{operation=~\"begin_tx|commit_tx|abort_tx|add_offsets|add_message\"}[5m]))",
          "legendFormat": "{{operation}} {{status}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Transactional Operations",
      "type": "timeseries"
    },
    {
